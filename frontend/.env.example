VITE_SUPABASE_URL=SUPABASE_URL_HERE
VITE_SUPABASE_KEY=SUPABASE_KEY_HERE

# Base URL of the Flask backend
# Local development: leave blank so Vite proxies /api to Flask
# Production/Vercel: REQUIRED. Set to the deployed Render backend URL
# Example: https://your-backend.onrender.com
VITE_API_URL=

VITE_STRIPE_PUBLISHABLE_KEY=pk_your_publishable_key_here