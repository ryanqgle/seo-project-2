VITE_SUPABASE_URL=SUPABASE_URL_HERE
VITE_SUPABASE_KEY=SUPABASE_KEY_HERE

# Base URL of the Flask backend. Leave BLANK for local development. The Vite
# dev server proxies /api to 127.0.0.1:5000 (see vite.config.js).
# In production (Vercel) set this to the deployed Render backend URL
VITE_API_URL=
VITE_STRIPE_PUBLISHABLE_KEY=pk_your_publishable_key_here
